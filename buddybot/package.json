{
  "name": "buddybot",
  "version": "1.0.0",
  "description": "An AI-powered Minecraft companion built with Mineflayer and the OpenAI API",
  "main": "index.js",
  "scripts": {
    "check": "npm test && npm run security:audit",
    "security:audit": "npm audit --audit-level=moderate",
    "test": "node --test",
    "start": "node index.js"
  },
  "keywords": [
    "minecraft",
    "mineflayer",
    "openai",
    "ai-agent"
  ],
  "author": "Florian Celibashi",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Florian-Celibashi/Buddybot-2.0.git"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "minecraft-data": "^3.100.0",
    "mineflayer": "^4.33.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "openai": "^6.48.0"
  },
  "overrides": {
    "@azure/msal-node": {
      "uuid": "11.1.1"
    },
    "yggdrasil": {
      "uuid": "11.1.1"
    }
  }
}
